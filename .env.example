# Database
DATABASE_URL=postgresql://governance:governance@localhost:5432/data_governance
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Application
APP_ENV=development
APP_DEBUG=false
APP_LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000

# Quality Engine
QUALITY_CHECK_TIMEOUT_SECONDS=300
QUALITY_MAX_CONCURRENT_CHECKS=5

# Alerting
ALERT_WEBHOOK_URL=
ALERT_EMAIL_SMTP_HOST=
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# Great Expectations
GE_DATA_CONTEXT_ROOT_DIR=./ge_data_context

# Soda
SODA_DATASOURCE_NAME=governance_db
